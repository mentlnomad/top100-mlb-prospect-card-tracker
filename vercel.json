{
  "rewrites": [
    { "source": "/api/prices", "destination": "/api/prices" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=21600, stale-while-revalidate=43200" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
